# ==========================================
# Terraform
# ==========================================

# State files - contain secrets, MUST not be in git
*.tfstate
*.tfstate.*
*.tfstate.backup

# Local .terraform directories (downloaded providers, modules)
**/.terraform/*
**/.terraform.lock.hcl.bak

# Variable files - may contain secrets
*.tfvars
*.tfvars.json
!*.example.tfvars

# Plan files - may contain sensitive data
*.tfplan
*.tfplan.*

# Crash logs
crash.log
crash.*.log

# CLI configuration
.terraformrc
terraform.rc

# ==========================================
# .NET
# ==========================================
bin/
obj/
*.user
*.suo
.vs/

# ==========================================
# Node / React
# ==========================================
node_modules/
dist/
build/
.next/
.env
.env.local
.env.*.local
*.log
.DS_Store

# ==========================================
# Editor / OS
# ==========================================
.idea/
.vscode/settings.json
*.swp
*.swo
Thumbs.db
.DS_Store

# ==========================================
# Secrets
# ==========================================
*.pem
*.key
*.pfx
*.p12
secrets/
.env
.envrc

# ==========================================
# Azure
# ==========================================
.azure/
azureauth.json

# Plan files - any file ending in .tfplan or named tfplan
tfplan
*.tfplan

# Backend configuration files (contain environment-specific resource names)
backend.config
*.backend.config
